{
  "name": "basic",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode client && vite build",
    "dev:remote": "vite build && wrangler dev --remote",
    "preview": "wrangler dev",
    "deploy:prod": "pnpm run build && wrangler deploy --env=production",
    "deploy:staging": "pnpm run build && wrangler deploy --env=staging",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "push:blogs:local": "pnpm run reset:content:local && node seeds/push-blogs.mjs --local",
    "push:blogs:prod": "node seeds/fetch-blogs-from-local.mjs --prod && node seeds/push-blogs.mjs --prod",
    "push:resume-assets:local": "node seeds/push-resume-assets.mjs --local",
    "push:resume-assets:prod": "node seeds/push-resume-assets.mjs --prod",
    "push:content:local": "pnpm run push:blogs:local && pnpm run push:resume-assets:local",
    "push:content:prod": "pnpm run push:blogs:prod && pnpm run push:resume-assets:prod",
    "fetch:blogs:prod": "node seeds/fetch-blogs-from-prod.mjs",
    "fetch:resume-assets:prod": "node seeds/fetch-resume-assets-from-prod.mjs",
    "fetch:content:prod": "pnpm run fetch:blogs:prod && pnpm run fetch:resume-assets:prod",
    "reset:content:local": "rm -rf .wrangler/state && pnpm run fetch:content:prod && pnpm run push:content:local",
    "prepare": "lefthook install && chmod +x .github/hooks/scripts/*.sh"
  },
  "dependencies": {
    "extend": "^3.0.2",
    "gray-matter-es": "^0.2.1",
    "hono": "^4.11.7",
    "honox": "0.1.52",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "@hono/vite-build": "^1.3.0",
    "@hono/vite-dev-server": "^0.18.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.0.9",
    "lefthook": "^1.11.0",
    "oxc-parser": "^0.67.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.0.0",
    "tailwindcss": "^4.0.9",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vitest": "^4.0.18",
    "wrangler": "^4.64.0"
  }
}
